# Postgres 18+ expects mount at /var/lib/postgresql (image uses versioned subdir, e.g. 18/)
# Server: 64GB RAM — all given to Postgres (Trino not deployed)
services:
  postgres:
    environment:
      POSTGRES_PASSWORD: "{{ postgres_password }}"
    volumes:
      - {{ data_mount }}/postgres:/var/lib/postgresql
    deploy:
      resources:
        limits:
          memory: 48G
    command: >
      postgres
      -c shared_buffers=16GB
      -c effective_cache_size=36GB
      -c maintenance_work_mem=2GB
      -c checkpoint_timeout=30min
      -c max_wal_size=4GB
      -c min_wal_size=1GB
      -c wal_buffers=64MB
      -c synchronous_commit=off
      -c wal_writer_delay=1000ms
      -c random_page_cost=1.1
      -c max_parallel_workers=16
      -c max_parallel_workers_per_gather=4
      -c parallel_setup_cost=0
      -c parallel_tuple_cost=0
